@page
@model presentacion_series.Pages.Ventanas.CategoriasModel
@{
    ViewData["Title"] = "Categorias";
}

<center>
    <div>
        <form method="POST" enctype="multipart/form-data">
            @Html.AntiForgeryToken()

            <div align="left">
                <h3>Categorias</h3>
            </div>

            <div>
                <input type="submit" value="Refrescar"
                       class="btn btn-secondary"
                       asp-page-handler="BtRefrescar" />
                <input type="submit" value="Nuevo"
                       class="btn btn-secondary"
                       asp-page-handler="BtNuevo"
                       disabled="@(Model.Venta != null)" />
                <input type="submit" value="Guardar"
                       class="btn btn-secondary"
                       asp-page-handler="BtGuardar"
                       disabled="@(Model.Venta == null)" />
            </div>

            @if (Model.Venta != null)
            {
                <input type="hidden" asp-for="@Model.Venta!.Id" />
                <div>
                    <div class="form-group">
                        <label>Nombre</label>
                        <div class="col-6">
                            <input class="form-control" asp-for="@Model.Venta!.Nombre" />
                        </div>
                    </div>
                    <div class="form-group">
                        <label>Descripcion</label>
                        <div class="col-6">
                            <input class="form-control" asp-for="@Model.Venta!.Descripcion" />
                        </div>
                    </div>
                </div>
            }

            @if (Model.Venta != null && Model.Borrando)
            {
                <div class='popup'>
                    <div class='pp_ms_inner'>
                        <div style='width:95%'>
                            <h2 align="left">Mensaje</h2>
                            <h6 align="left">¿Desea borrar la Categoria?</h6>
                            <h6 align="left">@Model.Venta!.Id</h6>
                            <input type="submit" value="Cerrar"
                                   asp-page-handler="BtCerrar"
                                   class="btn btn-secondary" />
                            <input type="submit" value="Borrar"
                                   asp-page-handler="BtBorrar"
                                   class="btn btn-secondary" />
                        </div>
                    </div>
                </div>
            }

            @if (Model?.Lista?.Count > 0)
            {
                <table class="tb_data table table-striped table-bordered table-hover">
                    <tr>
                        <th>Id</th>
                        <th>Nombre</th>
                        <th>Descripcion</th>
                        <th>Acciones</th>
                    </tr>
                    @foreach (var elemento in Model.Lista)
                    {
                        <tr>
                            <td>@elemento.Id</td>
                            <td>@elemento.Nombre</td>
                            <td>@elemento.Descripcion</td>
                            <td>
                                <input type="submit" value="Modificar"
                                       asp-page-handler="BtModificar"
                                       class="btn btn-secondary"
                                       asp-route-data="@elemento.Id" />
                                <input type="submit" value="Borrar"
                                       asp-page-handler="BtBorrarVal"
                                       class="btn btn-secondary"
                                       asp-route-data="@elemento.Id" />
                            </td>
                        </tr>
                    }
                </table>
            }
        </form>
    </div>
</center>